---
import { mergeClassNames } from '../utils.ts';

type Props = { 
  href: string;
  external?: boolean;
  color?: string;
  class?: string;
};

const { href, external, color, class: className } = Astro.props;
---

<a
  href={href}
  target={external ? '_blank' : '_self'}
  rel={external ? 'noreferrer' : undefined}
  class={mergeClassNames(
    'inline-block text-[var(--link)] transition-colors duration-200 ease-out hover:underline hover:underline-offset-[2px] hover:text-[var(--link-hover)] focus-visible:outline-none focus-visible:underline focus-visible:underline-offset-[2px] focus-visible:text-[var(--link-hover)]',
    className,
  )}
>

  <slot />
</a>
