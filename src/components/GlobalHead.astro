---
import { Font } from 'astro:assets';
---

<!-- Global Metadata -->
<meta charset='utf-8' />
<meta name='viewport' content='width=device-width, initial-scale=1.0' />
<link rel='icon' href='/favicon.ico' />
<link rel='icon' type='image/png' sizes='16x16' href='/favicon-16x16.png' />
<link rel='icon' type='image/png' sizes='32x32' href='/favicon-32x32.png' />
<link data-theme-favicon rel='icon' type='image/svg+xml' sizes='any' href='/favicon.svg' />
<link rel='apple-touch-icon' sizes='180x180' href='/apple-touch-icon.png' />
<meta data-theme-color name='theme-color' content='#211e1b' />
<script is:inline>
  (() => {
    const root = document.documentElement;
    const favicon = document.querySelector("link[data-theme-favicon]");
    const themeColor = document.querySelector("meta[data-theme-color]");
    const themeAssets = {
      light: {
        color: "#fbfbfb",
        favicon: "/favicon-light.svg",
      },
      dark: {
        color: "#211e1b",
        favicon: "/favicon-dark.svg",
      },
    };

    const syncThemeAssets = () => {
      const theme = root.classList.contains("theme-light") ? "light" : "dark";
      const assets = themeAssets[theme];
      favicon?.setAttribute("href", assets.favicon);
      themeColor?.setAttribute("content", assets.color);
    };

    syncThemeAssets();
    new MutationObserver(syncThemeAssets).observe(root, {
      attributes: true,
      attributeFilter: ["class"],
    });
  })();
</script>
<meta name='generator' content={Astro.generator} />

<Font cssVariable='--font-inter' preload />
<Font cssVariable='--font-cascadia-mono' preload />

<style>
    body {
      font-family: var(--font-inter);
    }
</style>
