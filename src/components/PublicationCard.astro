---
import type { ImageMetadata } from "astro";
import type { CollectionEntry } from "astro:content";
import Link from "@components/Link.astro";
import { Image } from "astro:assets";

type Props = {
  publication: CollectionEntry<"publications">;
  publicationCardImage: ImageMetadata;
};

const { publication, publicationCardImage } = Astro.props as Props;

let websitePath: string;
let isLocal = false;
if (publication.data.website !== "local") {
  websitePath = publication.data.website;
  isLocal = false;
} else {
  websitePath = `/publications/${publication.id}`;
  isLocal = true;
}

const externalAffiliatedLinks = publication.data.externalAffiliatedLinks
  .split(", ")
  .map((link: string) => {
    const [name, url] = link.split(": ");
    return { name, url };
  });

const localAffiliatedLinks = publication.data.localAffiliatedLinks
  .split(", ")
  .map((link: string) => {
    const [name, url] = link.split(": ");
    return { name, url };
  });

let authors: string;
if (publication.data.trim_names == true) {
  authors = publication.data.authors
    .split(", ")
    .map((author: string) => {
      const nameParts = author.split(" ");
      const lastName = nameParts.pop();
      const initials = nameParts.map((part: string) => part.charAt(0) + ".").join(" ");
      return `${initials} ${lastName}`;
    })
    .join(", ");
} else {
  authors = publication.data.authors;
}

if (publication.data.etal === true) {
  authors = `${authors}, et al.`;
}
---

<div class="grid grid-cols-1 gap-x-4 gap-y-2 rounded-md border border-[var(--border-soft)] bg-[var(--surface)] p-4 shadow-[0_1px_0_rgba(0,0,0,0.04)] transition-[background-color,border-color,box-shadow] duration-200 ease-out hover:border-[var(--border)] hover:bg-[var(--surface-elevated)] hover:shadow-md lg:grid-cols-7 lg:gap-x-8">
  <div class="hidden lg:col-span-2 lg:flex lg:items-center lg:justify-center">
    <Image
      src={publicationCardImage}
      alt={publication.data.title}
      class="rounded-md object-cover"
      loading="eager"
    />
  </div>

  <div class="flex flex-col justify-center lg:col-span-5">
    <Link href={websitePath} class="mb-2 block md:mb-3" external={isLocal !== true}>
      {publication.data.title}
    </Link>

    <div class="mt-1 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-[var(--muted)]">
      {authors}
    </div>

    <div class="mt-1 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-[var(--muted)]">
      @ {publication.data.confShort}
      <span class="text-[var(--muted)] text-sm" aria-hidden="true">|</span>

      {externalAffiliatedLinks && externalAffiliatedLinks.length > 0 && (
        <ul class="flex flex-wrap gap-x-3 gap-y-1">
          {externalAffiliatedLinks.map((link: { name: string; url: string }) => (
            <li>
              <Link href={link.url} external>
                {link.name}
              </Link>
            </li>
          ))}
        </ul>
      )}

      {localAffiliatedLinks && localAffiliatedLinks.length > 0 && (
        <ul class="flex flex-wrap gap-x-3 gap-y-1">
          {localAffiliatedLinks.map((link: { name: string; url: string }) => (
            <li>
              <Link href={`/publications/${publication.id}/${link.url}`} external>
                {link.name}
              </Link>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</div>
